{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/src/pages/(.*).html",
      "destination": "/$1.html"
    },
    {
      "source": "/src/pages/(.*)",
      "destination": "/$1.html"
    },
    {
      "source": "/((?!src|assets|node_modules|public).* )",
      "destination": "/$1.html"
    }
  ]
}
